# PostHog Analytics Configuration
# Get your Project API Key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key_here

# PostHog Host URL
# Use https://us.i.posthog.com for US cloud
# Use https://eu.i.posthog.com for EU cloud
# Use https://app.posthog.com for legacy hosting
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Bunny.net CDN Configuration
# Your custom Bunny CDN hostname (e.g., yourzone.b-cdn.net)
# Leave empty to serve images from local /public directory
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=
